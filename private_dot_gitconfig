[includeIf "gitdir:~/go/src/github.com/"]
  path = .gitconfig-github

[includeIf "gitdir:~/go/src/gitlab.com/"]
  path = .gitconfig-gitlab

[includeIf "gitdir:~/go/src/gitlab.com/xolv/"]
  path = .gitconfig-gitlab-xolv

[includeIf "gitdir:~/go/src/gitlab.com/xolvdotcom/"]
  path = .gitconfig-gitlab-xolv

[core]
  editor = vim
  pager = less -xR
  excludesfile = ~/.gitignore

[user]
  signingkey = ~/.ssh/id_ed25519.pub

[gpg]
  format = ssh

[gpg "ssh"]
  allowedSignersFile = ~/.gitconfig-allowed-signers

[commit]
  gpgsign = true

[tag]
  gpgsign = true

[advice]
  # ignore horrible advice when push fails
  pushNonFastForward = false

[stash]
  showPatch = true

[pull]
  rebase = true

[init]
  defaultBranch = master

[diff]
  tool = icdiff

[difftool]
  prompt = false

[difftool "icdiff"]
  cmd = icdiff --line-numbers $LOCAL $REMOTE

[alias]
  df      = difftool
  stats   = shortlog -sn --all --no-merges
  recent  = for-each-ref --count=10 --sort=-committerdate refs/heads/ --format="%(refname:short)"
  graph   = log --graph --all --decorate --stat --date=iso
  root    = rev-parse --show-toplevel
  fixup   = "!f() { \
      REMOTE=$(git config --get remote.origin.url); \
      MASTER=$(git remote show ${REMOTE} | grep 'HEAD branch' | cut -d ' ' -f 5); \
      BRANCH=${1:-${MASTER}}; \
      git reset --soft ${BRANCH}; \
    }; f"
  lo      = log --oneline
  sha     = rev-parse --short HEAD
  lsha    = rev-parse HEAD
  nbr     = "!f() { \
      NEW_BRANCH=$(date -u +\"%Y%m%d%H%M%S\"); \
      git checkout -b kr/${NEW_BRANCH}; \
    }; f"
